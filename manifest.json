{
  "name": "Gabon Sport Connect",
  "short_name": "GSC",
  "description": "Plateforme nationale de gestion du sport au Gabon",
  "start_url": "index.html",
  "scope": "./",
  "display": "standalone",
  "theme_color": "#009E60",
  "background_color": "#ffffff",
  "orientation": "portrait-primary",

  "icons": [
    {
      "src": "icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icon-1024.png",
      "sizes": "1024x1024",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icon-192-maskable.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "icon-512-maskable.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "icon-1024-maskable.png",
      "sizes": "1024x1024",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],

  "shortcuts": [
    {
      "name": "Gabon Sport Connect",
      "short_name": "GSC",
      "description": "Accueil - Plateforme de gestion du sport",
      "url": "index.html?source=shortcut",
      "icons": [{ "src": "icon-192.png", "sizes": "192x192", "type": "image/png" }]
    },
    {
      "name": "Console Admin",
      "short_name": "GSC Admin",
      "description": "Administration - Gestion centralisée",
      "url": "admin.html?source=shortcut",
      "icons": [{ "src": "icon-192.png", "sizes": "192x192", "type": "image/png" }]
    }
  ],

  "categories": ["sports", "productivity"],

  "screenshots": [
    { "src": "icon-512.png", "sizes": "512x512", "type": "image/png" }
  ],

  "share_target": {
    "action": "index.html",
    "method": "GET",
    "params": { "title": "title", "text": "text", "url": "url" }
  },

  "handle_links": "preferred",

  "launch_handler": {
    "client_mode": ["navigate-existing", "auto"]
  },

  "related_applications": [],
  "prefer_related_applications": false,

  "permissions": ["push", "notifications"]
}
